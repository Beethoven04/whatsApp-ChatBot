# ─── Meta / WhatsApp Cloud API ────────────────────────────────────────────────
# Found in: Meta for Developers → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=           # Permanent or temporary access token
WHATSAPP_PHONE_ID=1161539513701346  # Phone Number ID (not the number itself)
WHATSAPP_VERIFY_TOKEN=    # Any string you choose — must match what you set in the webhook config
WHATSAPP_APP_SECRET=      # App Secret from App Dashboard → Settings → Basic (used for signature verification)

# ─── Google AI (Gemini 2.5 Flash) ─────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/apikey
# Free tier: 10 requests/min, 500 requests/day
GOOGLE_API_KEY=AIza...

# ─── Escalation ───────────────────────────────────────────────────────────────
# Manager's WhatsApp number (with country code, no + or spaces)
MANAGER_PHONE=212777933465

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
